meta {
  name: login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: inherit
}

body:json {
  {
      "email": "yoga@studio.com",
      "password": "test!1234"
  }
}

script:post-response {
  if (res.status === 200 && res.body.token) {
    bru.setVar("authToken", res.body.token);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
